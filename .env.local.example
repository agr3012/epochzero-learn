# =====================================================================
# REMA Club — Environment Variables
# Copy to .env.local for local dev. Set on Vercel for production.
# =====================================================================

# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... (anon public key)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... (service_role key — KEEP SECRET, server-only)

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Must be a verified sender on a domain you control.
# For testing you can use 'onboarding@resend.dev'.
RESEND_FROM_EMAIL=REMA Club <noreply@yourdomain.com>

# --- App ---
# Production: your Vercel URL (or custom domain). NO trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used by the admin bootstrap script (optional)
ADMIN_BOOTSTRAP_EMAIL=you@example.com

# --- Cloudflare Turnstile (optional anti-bot for OTP requests) ---
# https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
